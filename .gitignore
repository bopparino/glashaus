.vscode/
.idea/
*.swp
*.swo
*~
.DS_Store

# --- macOS ---
.AppleDouble
.LSOverride
Icon
._*
.DocumentRevisions-V100
.fseventsd
.Spotlight-V100
.TemporaryItems
.Trashes
.VolumeIcon.icns
.com.apple.timemachine.donotpresent

# --- GlasHaus runtime state (must never be committed) ---
# The state DB lives in ~/.glashaus/, never the repo, but defensive in case
# someone symlinks or copies it into the tree.
*.db
*.db-journal
*.db-wal
*.db-shm
.glashaus/
state/
logs/

# --- Secrets ---
.env
.env.*
!.env.example
secrets/
*.pem
*.key
