# GlasHaus is configured by `glashaus setup` → ~/.glashaus/config.json.
# Environment variables OVERRIDE the config file — useful for services,
# testing, or running several instances. Nothing here is required.

# Where the instance lives (config, persona, brain, logs, backups)
#GLASHAUS_HOME=~/.glashaus

# Ollama
#OLLAMA_HOST=http://127.0.0.1:11434
#GLASHAUS_MODEL=llama3.1:8b
#GLASHAUS_EMBED_MODEL=nomic-embed-text
#GLASHAUS_MAX_TOKENS=4096
#GLASHAUS_TEMPERATURE=          # unset = model default; replies only
#GLASHAUS_MIN_P=                # e.g. 0.05; replies only

# Identity (normally in config.json)
#GLASHAUS_COMPANION_NAME=
#GLASHAUS_USER_NAME=
#GLASHAUS_TIMEZONE=America/New_York
#GLASHAUS_LOCATION=

# Telegram (normally in config.json, chmod 600)
#TELEGRAM_BOT_TOKEN=
#TELEGRAM_OWNER_ID=

# Memory cadence
#GLASHAUS_RECENT_WINDOW=40      # messages kept verbatim in context
#GLASHAUS_SUMMARIZE_CHUNK=30    # older messages condensed per episode
#GLASHAUS_CAPTURE_EVERY=8       # exchanges between fact-extraction passes

# Schedules (cron syntax, instance timezone)
#GLASHAUS_DREAM_CRON=30 3 * * *
#GLASHAUS_CONSOLIDATE_CRON=50 3 * * *
#GLASHAUS_BACKUP_CRON=15 4 * * *
#GLASHAUS_HEARTBEAT_CRON=*/30 * * * *

# Heartbeat guardrails
#GLASHAUS_QUIET_START=23
#GLASHAUS_QUIET_END=8.5
#GLASHAUS_MIN_SILENCE_HOURS=3
#GLASHAUS_MAX_PER_DAY=3
#GLASHAUS_MIN_GAP_HOURS=2.5

# Webview
#GLASHAUS_VIEW_PORT=7777
#GLASHAUS_VIEW_BIND=127.0.0.1

# Backups
#GLASHAUS_BACKUP_DIR=~/.glashaus/backups
#GLASHAUS_BACKUP_KEEP_DAYS=30
